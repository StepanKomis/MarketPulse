# ── MarketPulse — environment variables ──────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── App ──────────────────────────────────────────────────────────────────────
PORT=8000
ENV=development           # development | production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://marketpulse:marketpulse@localhost:5432/marketpulse
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ── Binance ──────────────────────────────────────────────────────────────────
# Symbols to track — lowercase, comma-separated.
SYMBOLS=btcusdt,ethusdt,bnbusdt,solusdt

# How often to flush accumulated tickers to the database (milliseconds).
# Lower = more writes, higher resolution. Binance sends ~1 update/symbol/sec.
SAVE_INTERVAL_MS=2000

# Maximum WebSocket reconnect delay (milliseconds).
WS_MAX_RECONNECT_MS=30000
